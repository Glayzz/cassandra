# Cassandra - Pre-Loss Oracle for Wallets (EVM + Solana)
# Copy to .env and fill in.

# ---- EVM ----
# Etherscan API v2 (multichain, one key covers Ethereum/Base/Arbitrum/Optimism/
# Polygon/BSC). Free tier: 5 calls/sec, 100k/day. REQUIRED for EVM tools.
# Get one at https://etherscan.io/apis
ETHERSCAN_API_KEY=YourApiKeyToken

# Alchemy (optional - richer/faster EVM reads). https://www.alchemy.com
ALCHEMY_API_KEY=

# ---- Solana ----
# Public RPC works out of the box but is heavily rate-limited. For the demo,
# set a Helius / QuickNode / Alchemy-Solana URL below, OR a Helius key.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Helius key (recommended for Solana). Unlocks a faster RPC AND the DAS API,
# which gives token name/symbol/metadata in foresee_token. https://helius.dev
HELIUS_API_KEY=

# GoPlus Security (optional). Powers pro token security, honeypot/tax detection,
# and malicious-address intel. The free anonymous tier works with NO key; set one
# only to raise rate limits. https://gopluslabs.io
GOPLUS_API_KEY=

# ---- Optional ----
# Anthropic Claude (reserved for richer narration; not required to run).
ANTHROPIC_API_KEY=

# ---- Server ----
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
DEFAULT_CHAIN_ID=1
